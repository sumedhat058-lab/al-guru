@charset "utf-8";

* { margin: 0px; padding: 0px; box-sizing: border-box; }

body { font-family: "Segoe UI", sans-serif; background: rgb(15, 23, 42); color: rgb(255, 255, 255); min-height: 100vh; }

.header { background: linear-gradient(135deg, rgb(30, 58, 138), rgb(59, 130, 246)); padding: 2rem 1rem; text-align: center; box-shadow: rgba(59, 130, 246, 0.3) 0px 4px 20px; }

.header h1 { font-size: 2.5rem; margin-bottom: 0.5rem; }

.header p { opacity: 0.9; font-size: 1.1rem; }

.container { max-width: 1200px; margin: 2rem auto; padding: 0px 1rem; display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem; }

.card { background: rgb(30, 41, 59); border-radius: 16px; padding: 2rem; text-align: center; transition: transform 0.3s, box-shadow 0.3s; border: 1px solid rgb(51, 65, 85); }

.card:hover { transform: translateY(-5px); box-shadow: rgba(59, 130, 246, 0.4) 0px 10px 30px; }

.card h2 { color: rgb(96, 165, 250); margin-bottom: 1rem; font-size: 1.8rem; }

.card p { margin-bottom: 1.5rem; opacity: 0.8; line-height: 1.6; }

.btn { background: rgb(59, 130, 246); color: white; border-width: medium; border-style: none; border-color: currentcolor; border-image: initial; padding: 0.8rem 1.5rem; border-radius: 8px; font-size: 1rem; cursor: pointer; width: 100%; transition: background 0.3s; }

.btn:hover { background: rgb(37, 99, 235); }

.footer { text-align: center; padding: 2rem; margin-top: 3rem; opacity: 0.6; font-size: 0.9rem; }
